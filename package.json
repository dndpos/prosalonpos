{
  "name": "prosalonpos-server",
  "version": "1.0.0",
  "description": "ProSalonPOS Backend API Server",
  "type": "module",
  "scripts": {
    "dev": "npx prisma generate && node --watch src/server.js",
    "start": "node src/server.js",
    "start:prod": "cross-env PORT=3002 node src/server.js",
    "postinstall": "prisma generate",
    "build:railway": "node scripts/build-railway.js",
    "db:migrate": "npx prisma migrate dev",
    "db:reset": "npx prisma migrate reset --force",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "build:sqlite": "node scripts/build-sqlite.js",
    "build:exe": "node scripts/build-exe.js"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "5.22.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.5",
    "twilio": "^5.5.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  }
}
