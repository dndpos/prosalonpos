// ════════════════════════════════════════════
// PROVIDER (ISO) — manages multiple salons
// ════════════════════════════════════════════

model ProviderOwner {
  id                  String   @id @default(uuid())
  name                String
  email               String?  @unique              // cc4.6.1: required by provider.js findUnique({ where: { email } }). Used to be enforced by a stray DB constraint — cc4.5's prisma db push dropped it, which is what broke login.
  pin_hash            String                        // bcrypt hashed PIN
  locked              Boolean  @default(false)       // C64: locked after 5 failed attempts
  failed_attempts     Int      @default(0)           // C64: consecutive failed login count
  locked_at           DateTime?                      // C64: when the lock happened
  reset_code          String?                        // C64: 6-digit reset code (hashed)
  reset_code_expires  DateTime?                      // C64: reset code expiry (15 min)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}

model ProviderAgent {
  id                  String   @id @default(uuid())
  name                String
  email               String?
  pin_hash            String                        // bcrypt hashed PIN
  role                String   @default("support")  // support | sales
  visibility          String   @default("assigned") // all | assigned
  active              Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  assigned_salons     Salon[]
}

model ProviderSalonNote {
  id         String   @id @default(uuid())
  salon_id   String
  agent_id   String                         // provider owner or agent ID
  agent_name String
  content    String
  created_at DateTime @default(now())

  salon Salon @relation(fields: [salon_id], references: [id])

  @@index([salon_id])
}

model ProviderBillingRecord {
  id           String @id @default(uuid())
  salon_id     String
  amount_cents Int
  date         String                        // YYYY-MM-DD
  status       String @default("pending")    // pending | paid | overdue | trial
  method       String @default("N/A")        // ACH | Credit Card | N/A
  created_at   DateTime @default(now())

  salon Salon @relation(fields: [salon_id], references: [id])

  @@index([salon_id])
}

model ProviderAuditLog {
  id         String   @id @default(uuid())
  actor_id   String                          // provider owner or agent ID
  actor_name String
  action     String                          // feature_toggled | note_added | salon_created | salon_updated | salon_suspended | agent_created | agent_updated
  detail     String
  salon_id   String?
  created_at DateTime @default(now())

  @@index([salon_id])
  @@index([actor_id])
}

// ════════════════════════════════════════════
// MULTI-OWNER PORTAL (v2.1.3)
// Person-level owner accounts that can access one or more salons.
// SEPARATE from Salon.owner_pin_* (which stays for station/manager use).
// SEPARATE from ProviderOwner (the ISO/master provider).
// ════════════════════════════════════════════

model SalonOwnerAccount {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  pin_hash          String                                   // bcrypt hashed personal PIN
  pin_plain         String?                                  // plain PIN visible to provider only (for handoff/reset)
  must_change_pin   Boolean  @default(true)                  // forced change on first portal login
  active            Boolean  @default(true)
  last_login_at     DateTime?
  last_salon_id     String?                                  // remember last-used salon for next login
  failed_attempts   Int      @default(0)                     // brute-force tracking
  locked            Boolean  @default(false)
  locked_at         DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  salon_access      SalonOwnerAccess[]
}

// ════════════════════════════════════════════
// STATIONS (v2.2.0)
// Persistent record per paired device. Created on first socket connect via
// upsert keyed on station_id (UUID generated client-side at pairing time).
// One station per salon may be flagged is_main — used as the default for
// shared-terminal routing and "all stations" report scope. Does NOT affect
// per-terminal batch close (each terminal closes its own batch via Fiserv).
// ════════════════════════════════════════════

model Station {
  id          String   @id                                  // matches client-generated station_id (NOT @default(uuid()))
  salon_id    String
  label       String                                        // "Station 1", "Front Desk", "Tablet 2"
  is_main     Boolean  @default(false)
  last_seen   DateTime @default(now())                      // updated on each socket join
  // v2.2.6: Station's primary LAN IPv4 address, captured by the Electron
  // shell at socket join. Used by V2.3 Phase 2 offline mode so peer stations
  // can route to the main station over the local network when internet is
  // down. Nullable: pre-2.2.6 stations + browser-mode (no Electron) leave it
  // null. Updated on every socket join — IPs change with DHCP leases.
  lan_ip      String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  salon Salon @relation(fields: [salon_id], references: [id], onDelete: Cascade)

  @@unique([salon_id, label])
  @@index([salon_id])
  @@index([salon_id, is_main])
}

model SalonOwnerAccess {
  id          String   @id @default(uuid())
  owner_id    String
  salon_id    String
  created_at  DateTime @default(now())

  owner SalonOwnerAccount @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  salon Salon             @relation(fields: [salon_id], references: [id], onDelete: Cascade)

  @@unique([owner_id, salon_id])
  @@index([owner_id])
  @@index([salon_id])
}

