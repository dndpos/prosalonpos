// ════════════════════════════════════════════
// PUSH NOTIFICATIONS
// ════════════════════════════════════════════

model PushSubscription {
  id           String   @id @default(uuid())
  salon_id     String
  staff_id     String
  endpoint     String   @unique
  keys_p256dh  String
  keys_auth    String
  created_at   DateTime @default(now())

  @@index([salon_id, staff_id])
}

// cc15: barcode-scoped audit log. Every write that touches a ticket's
// lifecycle (create, update/hold, reopen, combine, scan, close, void,
// refund) writes one row here, keyed by the stable `short_id` that
// appears on the check-in slip's barcode. Lets the cashier (or Cindy) see
// the full timeline for a ticket from slip-print to close, so dropped
// adjustments or orphaned merges surface immediately instead of hiding.
model SlipEvent {
  id             String   @id @default(uuid())
  salon_id       String
  short_id       String                             // 8-hex last of appointment id (lowercase)
  appointment_id String?
  ticket_id      String?                            // ticket-at-event-time (may change across merges)
  event_type     String                             // see SLIP_EVENT_TYPES in utils/slipLog.js
  payload        Json?                              // event-specific detail (items snapshot, merge target, etc.)
  station_id     String?
  staff_id       String?
  staff_name     String?
  created_at     DateTime @default(now())

  @@index([salon_id, short_id, created_at])
  @@index([salon_id, created_at])
}

// cc25 — Appointment Activity Log.
// Persistent server-side log of every appointment-level action: book, move,
// transfer, status change, add time, add service, check-in, walk-in start,
// waitlist remove, break/end-break. Replaces the cc14-era client-only
// useState log that vanished on page refresh.
//
// Retention: 60 days, pruned nightly (server.js setInterval). Storage cost
// is negligible at salon volumes (~1 MB/salon for 30 days at 50 events/day).
//
// Search: client_name + client_phone are denormalized snapshots so the log
// works after a client is renamed/deleted. case-insensitive partial match
// on either column drives the popup's customer search box.
model ActivityLog {
  id             String   @id @default(uuid())
  salon_id       String
  created_at     DateTime @default(now())
  action         String                             // booked | moved | tech_change | status_change | add_time | add_service | check_in | start_working | waitlist_remove | break | end_break | etc.
  description    String                             // human-readable line shown in the popup
  client_name    String?                            // snapshot at event time
  client_phone   String?                            // snapshot at event time
  tech_name      String?
  tech_id        String?
  service_name   String?
  appointment_id String?                            // optional — break/walk-in events have none
  requested      Boolean  @default(false)
  changed_tech   Boolean  @default(false)
  payload        Json?                              // booking details (multi-client/multi-service array), other extras

  @@index([salon_id, created_at])
  @@index([salon_id, client_phone])
  @@index([salon_id, client_name])
}

// v2.3.2 — V2.3 Phase 3c: Offline-write idempotency.
// Every write the renderer issues carries a UUID4 in the X-Client-Op-Id header.
// When that write replays from a peer station's offline queue (or a peer just
// retries a fetch that timed out), the server caches the first response under
// (salon_id, key). A second call with the same key returns the cached body
// + status code instead of re-running the route handler. Prevents duplicate
// appointments / clients on retry.
//
// Retention: 24 hours. A nightly prune deletes rows older than that — the
// renderer never retries a write more than ~10 minutes after the original,
// so 24h is conservative.
model IdempotencyKey {
  id             String   @id @default(uuid())
  salon_id       String
  key            String                             // X-Client-Op-Id value (UUID4)
  method         String                             // POST | PUT | DELETE
  path           String                             // /appointments, /clients/:id, etc.
  status_code    Int                                // cached HTTP status
  response_body  Json                               // cached JSON response body
  created_at     DateTime @default(now())

  @@unique([salon_id, key])
  @@index([salon_id, created_at])
}
