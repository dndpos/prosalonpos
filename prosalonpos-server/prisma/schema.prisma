// ProSalonPOS Database Schema
// Phase 2 — matches TD-007 consolidated data model (38 entities)
// Every table has: id (UUID), salon_id, created_at, updated_at, version (for Phase 4 sync)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════
// SALON & AUTHENTICATION
// ════════════════════════════════════════════

model Salon {
  id         String   @id @default(uuid())
  salon_code String   @unique @default(uuid())
  name       String
  phone      String?
  email      String?
  address1   String?
  address2   String?
  logo_url   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  version    Int      @default(1)

  // Provider-managed fields (set by Provider Admin Panel, read by salon POS)
  owner_name                String?
  owner_phone               String?
  owner_email               String?
  status                    String   @default("active")      // active | trial | suspended | cancelled
  plan_tier                 String   @default("basic")       // basic | professional | premium
  station_count             Int      @default(1)
  license_key               String?  @unique
  processing_rate           Float    @default(2.49)          // credit card processing rate %
  monthly_software_fee_cents Int     @default(7900)          // $79/mo default
  signup_date               DateTime @default(now())
  trial_end_date            DateTime?
  assigned_agent_id         String?
  features_enabled          Json?                            // ["appointments", "client_profiles", ...]
  owner_pin_hash            String?                          // Owner PIN stored on salon, not in Staff table
  owner_pin_sha256          String?                          // SHA-256 of owner PIN for fast local lookup
  owner_pin_plain           String?                          // Plain text PIN for display in Salon Settings

  // C65: Setup lockout — brute force protection on station pairing
  setup_locked              Boolean  @default(false)         // true = no new stations can pair/login
  setup_failed_attempts     Int      @default(0)             // consecutive failed setup attempts
  setup_locked_at           DateTime?                        // when the lock happened
  login_locked               Boolean  @default(false)         // true = too many failed PIN attempts
  login_failed_attempts      Int      @default(0)             // consecutive failed PIN attempts
  login_locked_at            DateTime?                        // when the login lock happened

  // v2.0.6: Per-salon timezone (set at salon creation in provider admin)
  // Used by: auto-clockout cron, SMS formatters, timesheet display
  // NOTE: dayBounds (reports/checkout/appointments) still hardcoded ET as of v2.0.6
  timezone                  String   @default("America/New_York")

  // v2.1.5: per-salon SMS billing rate (cents per message). Default 2¢/msg.
  // Provider sets this; usage report multiplies count × rate.
  sms_rate_cents            Int      @default(2)

  // Relations
  staff              Staff[]
  service_categories ServiceCategory[]
  services           ServiceCatalog[]
  clients            Client[]
  appointments       Appointment[]
  salon_settings     SalonSettings?
  tickets            Ticket[]
  gift_cards         GiftCard[]
  loyalty_accounts   LoyaltyAccount[]
  loyalty_program    LoyaltyProgram?
  membership_plans   MembershipPlan[]
  product_categories ProductCategory[]
  products           Product[]
  suppliers          Supplier[]
  commission_rules   CommissionRule[]
  commission_tiers   CommissionTier[]
  message_templates  MessageTemplate[]
  message_log        MessageLogEntry[]
  blocked_times      BlockedTime[]
  provider_notes     ProviderSalonNote[]
  provider_billing   ProviderBillingRecord[]
  assigned_agent     ProviderAgent?          @relation(fields: [assigned_agent_id], references: [id])
  // v2.1.3: multi-owner portal access
  owner_accesses     SalonOwnerAccess[]
  // v2.2.0: persistent station records (one per paired device)
  stations           Station[]
  // v2.2.3: per-station batch close audit log
  batch_closes       BatchClose[]
}

// ════════════════════════════════════════════
// STAFF
// ════════════════════════════════════════════

model Staff {
  id                        String   @id @default(uuid())
  salon_id                  String
  display_name              String
  legal_name                String?
  photo_url                 String?
  photo_blob                Bytes?                          // cc4.5: JPEG bytes stored in DB; NEVER include in staff list queries (pulls megabytes)
  photo_mime                String?                         // 'image/jpeg'
  photo_updated_at          DateTime?                       // cache-bust stamp appended to photo_url as ?v=<ts>
  role                      String   @default("technician") // technician | manager | owner
  rbac_role                 String   @default("tech")       // tech | manager | owner
  pin_hash                  String                          // bcrypt hashed PIN
  pin_sha256                String?                         // SHA-256 of PIN for fast local lookup
  pin_plain                 String?                         // Plain 4-digit PIN (shown to non-owner staff in edit screen)
  badge_id                  String?
  active                    Boolean  @default(true)
  status                    String   @default("active")     // active | deactivated | deleted
  tech_turn_eligible        Boolean  @default(true)
  show_on_calendar          Boolean  @default(true)
  show_on_online_booking    Boolean  @default(true)
  pay_type                  String   @default("commission") // commission | hourly | salary
  commission_pct            Int      @default(0)
  daily_guarantee_cents     Int      @default(0)
  hourly_rate_cents         Int?
  commission_bonus_enabled  Boolean  @default(false)
  salary_amount_cents       Int?
  salary_period             String?                         // weekly | biweekly | monthly
  payout_check_pct          Int      @default(100)
  payout_bonus_pct          Int      @default(0)
  category_commission_rates Json?                           // { "cat-01": 45, "cat-03": 35 }
  retail_commission_pct     Int      @default(0)            // 2026-04-26: per-staff product commission %. 0 = no product commission. Replaces salon-wide setting (which is now ignored).
  permission_overrides      Json?                           // per-action overrides
  permissions               Json?                           // { void: true, refund: true, ... }
  schedule                  Json?                           // { mon: { enabled, start, end }, tue: ... }
  position                  Int      @default(0)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
  version                   Int      @default(1)

  salon                   Salon                    @relation(fields: [salon_id], references: [id])
  service_lines           ServiceLine[]
  service_staff           ServiceStaffAssignment[]
  category_staff          CategoryStaffAssignment[]
  clock_punches           ClockPunch[]

  @@index([salon_id])
  @@index([salon_id, active])
}

// ════════════════════════════════════════════
// SERVICE CATEGORIES & CATALOG
// ════════════════════════════════════════════

model ServiceCategory {
  id                       String  @id @default(uuid())
  salon_id                 String
  name                     String
  calendar_color           String  @default("#3B82F6")
  position                 Int     @default(0)
  active                   Boolean @default(true)
  show_on_online_booking   Boolean @default(true)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  version                  Int      @default(1)

  salon          Salon                      @relation(fields: [salon_id], references: [id])
  service_links  ServiceCatalogCategory[]
  category_staff CategoryStaffAssignment[]

  @@index([salon_id])
}

model ServiceCatalog {
  id                       String  @id @default(uuid())
  salon_id                 String
  name                     String
  calendar_color           String  @default("#3B82F6")
  default_duration_minutes Int     @default(30)
  price_cents              Int     @default(0)
  product_cost_cents       Int     @default(0)
  open_price               Boolean @default(false)
  requires_room            Boolean @default(false)
  active                   Boolean @default(true)
  online_booking_enabled   Boolean @default(true)
  description              String  @default("")
  position                 Int     @default(0)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  version                  Int      @default(1)

  salon          Salon                      @relation(fields: [salon_id], references: [id])
  category_links ServiceCatalogCategory[]
  service_staff  ServiceStaffAssignment[]
  service_lines  ServiceLine[]

  @@index([salon_id])
}

// Junction table: service belongs to multiple categories (TD-001 fix)
model ServiceCatalogCategory {
  id                 String @id @default(uuid())
  service_catalog_id String
  category_id        String
  position           Int    @default(0)

  service  ServiceCatalog  @relation(fields: [service_catalog_id], references: [id], onDelete: Cascade)
  category ServiceCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([service_catalog_id, category_id])
}

// Junction: which techs can perform which services
model ServiceStaffAssignment {
  id                 String @id @default(uuid())
  service_catalog_id String
  staff_id           String

  service ServiceCatalog @relation(fields: [service_catalog_id], references: [id], onDelete: Cascade)
  staff   Staff          @relation(fields: [staff_id], references: [id], onDelete: Cascade)

  @@unique([service_catalog_id, staff_id])
}

// Junction: which techs are assigned to which categories (bulk)
model CategoryStaffAssignment {
  id          String @id @default(uuid())
  category_id String
  staff_id    String

  category ServiceCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  staff    Staff           @relation(fields: [staff_id], references: [id], onDelete: Cascade)

  @@unique([category_id, staff_id])
}

// ════════════════════════════════════════════
// CLIENTS
// ════════════════════════════════════════════

model Client {
  id                       String   @id @default(uuid())
  salon_id                 String
  first_name               String
  last_name                String
  phone                    String?
  phone_digits             String?  // stripped digits for search
  email                    String?
  outstanding_balance_cents Int     @default(0)
  promo_opt_out            Boolean  @default(false)
  is_vip                   Boolean  @default(false)
  vip_manual_override      Boolean  @default(false)
  notes                    String?
  active                   Boolean  @default(true)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  version                  Int      @default(1)

  salon              Salon              @relation(fields: [salon_id], references: [id])
  appointments       Appointment[]
  loyalty_account    LoyaltyAccount?
  membership_account MembershipAccount?

  @@index([salon_id])
  @@index([salon_id, phone_digits])
  @@index([salon_id, last_name])
}

// ════════════════════════════════════════════
// APPOINTMENTS & SERVICE LINES
// ════════════════════════════════════════════

model Appointment {
  id                   String   @id @default(uuid())
  salon_id             String
  client_id            String?
  client_name          String?  // denormalized for fast display
  status               String   @default("pending") // pending | confirmed | checked_in | in_progress | completed | cancelled | no_show
  source               String   @default("staff")   // staff | online | walk_in | kiosk
  booking_group_id     String?
  requested            Boolean  @default(false)
  deposit_cents        Int      @default(0)
  deposit_status       String   @default("none")    // none | pending | collected | refunded
  walk_in              Boolean  @default(false)
  checked_in_at        DateTime?
  notes                String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  version              Int      @default(1)

  salon         Salon         @relation(fields: [salon_id], references: [id])
  client        Client?       @relation(fields: [client_id], references: [id])
  service_lines ServiceLine[]

  @@index([salon_id])
  @@index([salon_id, status])
}

model ServiceLine {
  id                 String   @id @default(uuid())
  appointment_id     String
  service_catalog_id String?
  staff_id           String
  starts_at          DateTime
  duration_minutes   Int
  calendar_color     String
  status             String   @default("pending")
  payment_method     String?  // set after checkout: cash, credit, giftcard, zelle, package
  client_name        String?  // denormalized
  service_name       String
  price_cents        Int      @default(0)
  position           Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  version            Int      @default(1)

  appointment Appointment    @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  service     ServiceCatalog? @relation(fields: [service_catalog_id], references: [id])
  staff       Staff          @relation(fields: [staff_id], references: [id])

  @@index([appointment_id])
  @@index([staff_id, starts_at])
  @@index([starts_at])
}

// ════════════════════════════════════════════
// BLOCKED / RESERVED TIME
// ════════════════════════════════════════════

model BlockedTime {
  id        String   @id @default(uuid())
  salon_id  String
  staff_id  String
  starts_at DateTime
  dur       Int      // duration in minutes
  start_min Int      // minutes from midnight (for grid rendering)
  end_min   Int
  block_type String  @default("blocked") // blocked | reserved
  reason    String?
  date_from DateTime?  // start of date range
  date_to   DateTime?  // end of date range
  repeat_type String @default("none") // none | daily | weekly | biweekly | monthly
  repeat_days String?  // comma-separated day numbers: 0=Sun,...6=Sat
  repeat_day_of_month Int?  // 1-31 for monthly
  repeat_start_week DateTime? // reference date for biweekly cycle
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  version    Int      @default(1)

  salon Salon @relation(fields: [salon_id], references: [id])

  @@index([salon_id, staff_id])
}

// ════════════════════════════════════════════
// TICKETS (CHECKOUT)
// ════════════════════════════════════════════

model Ticket {
  id                String   @id @default(uuid())
  salon_id          String
  ticket_number     Int      @default(0)       // daily sequential: 1, 2, 3...
  appointment_id    String?
  client_id         String?
  client_name       String?
  status            String   @default("open")  // open | paid | voided | refunded | merged
  merged_into       String?                    // ticket_id of absorber (set when status='merged')
  // cc15.4: full list of source appointment_ids when this ticket is a
  // merge absorber. Scalar `appointment_id` (above) historically held
  // only ONE value (the first source's), which orphaned every other
  // source slip from finding the absorber. Populated by merge-open and
  // merge-and-close routes with the unique list of source
  // appointment_ids. Any slip whose appointment_id is in this array
  // resolves to this absorber. Null for non-merged tickets.
  source_appointment_ids Json?
  display_number    String?                    // combined display like '4&6' (set on absorber)
  subtotal_cents    Int      @default(0)
  tax_cents         Int      @default(0)
  discount_cents    Int      @default(0)
  tip_cents         Int      @default(0)
  surcharge_cents   Int      @default(0)
  dual_pricing_cents Int     @default(0)       // dual pricing markup (baked into item prices for CC)
  deposit_cents     Int      @default(0)       // deposit applied from booking
  pkg_redeemed_cents Int     @default(0)       // package redemption deduction total
  total_cents       Int      @default(0)
  payment_method    String?                    // cash | credit | giftcard | zelle | split
  cashier_id        String?
  cashier_name      String?
  created_by_id     String?                    // staff_id who originally created/held the ticket
  created_by_name   String?                    // display name of creator
  edited_by_id      String?                    // last staff_id who edited and re-held the ticket
  edited_by_name    String?                    // display name of last editor
  tip_distributions Json?                      // [{staff_id, staff_name, amount_cents}]
  void_reason       String?
  void_by           String?                    // staff_id who voided
  void_at           DateTime?
  refund_cents      Int      @default(0)
  refund_reason     String?
  refund_by         String?                    // staff_id who refunded
  refund_at         DateTime?
  refund_history    Json?                      // [{items:[{itemId,name,amount_cents}],reason,method,by,at,tax_cents,tip_cents,pkgCreditsRestored}]
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  version           Int      @default(1)

  salon    Salon          @relation(fields: [salon_id], references: [id])
  items    TicketItem[]
  payments TicketPayment[]

  @@index([salon_id])
  @@index([salon_id, created_at])
  @@index([salon_id, ticket_number])
}

model TicketItem {
  id                   String @id @default(uuid())
  ticket_id            String
  type                 String @default("service") // service | product | giftcard | package
  name                 String
  price_cents          Int    @default(0)
  original_price_cents Int    @default(0)         // price before adjustment
  client_id            String?                    // set during merge for multi-client tickets
  tech_id              String?
  tech_name            String?
  service_id           String?
  product_id           String?
  color                String?                    // calendar color for service block
  // package_id String? — DEFERRED: add via migration when package checkout is needed

  ticket Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
}

model TicketPayment {
  id               String   @id @default(uuid())
  ticket_id        String
  method           String                            // cash | credit | giftcard | zelle
  sub_method       String?                           // C69: 'zelle' or 'venmo' — only set when method='zelle'
  amount_cents     Int
  gc_id            String?
  gc_code          String?
  card_brand       String?                           // VISA | MASTERCARD | AMEX | DISCOVER | etc
  last4            String?                           // last 4 digits of card
  auth_code        String?                           // authorization code from processor
  entry_method     String?                           // CHIP | TAP | SWIPE | MANUAL
  processor_txn_id String?                           // terminal RefNum — used for void/refund
  terminal_response Json?                            // full raw terminal response for audit
  // v2.2.3: station that wrote this payment (nullable for backward compat with
  // pre-v2.2.3 rows). NOT a hard FK — stations can be deleted without losing
  // payment history. Used by per-station Batch Close reconciliation.
  station_id       String?
  created_at       DateTime @default(now())

  ticket Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([station_id])
}

// ════════════════════════════════════════════
// BATCH CLOSE (v2.2.3) — per-station audit log
// ════════════════════════════════════════════
// Each PAX terminal still closes its OWN batch (Fiserv is per-terminal/MID),
// but we log every successful/failed close here so the salon can reconcile
// across all stations from one Daily Report panel.
//
// station_id + station_label are denormalized snapshots — the label is
// captured at close time so the report still reads correctly even if the
// station is renamed or deleted afterward. NO hard FK to Station.

model BatchClose {
  id                  String   @id @default(uuid())
  salon_id            String
  station_id          String?                        // nullable: should always be set in v2.2.3+, but defensive
  station_label       String                         // snapshot at close time
  closed_at           DateTime @default(now())
  closed_by_staff_id  String?
  closed_by_name      String?                        // 'Owner' | 'Provider' | staff display_name
  total_count         Int      @default(0)           // # transactions in batch (from PAX response)
  total_credit_cents  Int      @default(0)           // total settled amount
  total_tip_cents     Int      @default(0)
  status              String   @default("success")   // 'success' | 'failed'
  host_code           String?                        // PAX hostCode
  host_message        String?                        // PAX hostMessage
  tid                 String?
  mid                 String?
  error_message       String?                        // populated when status='failed'
  terminal_response   Json?                          // full PAX response for audit
  created_at          DateTime @default(now())

  salon Salon @relation(fields: [salon_id], references: [id], onDelete: Cascade)

  @@index([salon_id, closed_at])
  @@index([salon_id, station_id])
}

// ════════════════════════════════════════════
// SALON SETTINGS (single row per salon)
// ════════════════════════════════════════════

model SalonSettings {
  id       String @id @default(uuid())
  salon_id String @unique
  settings Json   // entire settings object stored as JSON
  version  Int    @default(1)
  updated_at DateTime @updatedAt

  salon Salon @relation(fields: [salon_id], references: [id])
}

// ════════════════════════════════════════════
// GIFT CARDS
// ════════════════════════════════════════════

model GiftCard {
  id                     String   @id @default(uuid())
  salon_id               String
  code                   String
  type                   String   @default("physical") // physical | digital
  initial_amount_cents   Int      @default(0)
  balance_cents          Int      @default(0)
  status                 String   @default("active") // active | depleted | deactivated
  client_id              String?              // linked client (recipient)
  client_name            String?
  purchased_by_client_id String?              // who bought it
  purchased_by_name      String?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
  version                Int      @default(1)

  salon        Salon                 @relation(fields: [salon_id], references: [id])
  transactions GiftCardTransaction[]

  @@unique([salon_id, code])
  @@index([salon_id])
}

model GiftCardTransaction {
  id                 String   @id @default(uuid())
  gift_card_id       String
  type               String                     // purchase | reload | redemption
  amount_cents       Int                        // positive for purchase/reload, negative for redemption
  balance_after_cents Int
  staff_id           String?
  staff_name         String?
  ticket_id          String?                    // linked ticket for redemptions
  created_at         DateTime @default(now())

  giftCard GiftCard @relation(fields: [gift_card_id], references: [id], onDelete: Cascade)

  @@index([gift_card_id])
}

// ════════════════════════════════════════════
// LOYALTY
// ════════════════════════════════════════════

model LoyaltyProgram {
  id                  String   @id @default(uuid())
  salon_id            String   @unique
  active              Boolean  @default(false)         // master toggle (Session 11 Decision #222)
  program_type        String   @default("flat")        // flat | tiered (Decision #222)
  earn_per_dollar     Float?                           // points per dollar spent (Decision #220)
  earn_per_visit      Int?                             // flat points per visit (Decision #220)
  expiration_months   Int?                             // null = never expire (Decision #225)
  redemption_mode     String   @default("manual")      // manual | automatic (Decision #226)
  tier_reset          String?                          // annual | permanent, null for flat (Decision #224)
  show_on_receipt     Boolean  @default(true)          // print points on receipt (Decision #229)
  points_name         String   @default("points")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  version             Int      @default(1)

  salon   Salon           @relation(fields: [salon_id], references: [id])
  tiers   LoyaltyTier[]
  rewards LoyaltyReward[]
}

model LoyaltyTier {
  id                String @id @default(uuid())
  program_id        String
  name              String
  min_points        Int    @default(0)        // threshold to reach this tier
  multiplier        Float  @default(1.0)      // point earning multiplier
  position          Int    @default(0)
  created_at        DateTime @default(now())
  version           Int      @default(1)

  program LoyaltyProgram @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@index([program_id])
}

model LoyaltyReward {
  id              String  @id @default(uuid())
  program_id      String
  name            String
  points_required Int     @default(0)       // cost in points
  type            String  @default("discount") // discount | freeService | product
  value_cents     Int     @default(0)       // dollar value of reward
  active          Boolean @default(true)
  position        Int     @default(0)
  created_at      DateTime @default(now())
  version         Int      @default(1)

  program LoyaltyProgram @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@index([program_id])
}

model LoyaltyAccount {
  id             String @id @default(uuid())
  salon_id       String
  client_id      String @unique
  points_balance Int    @default(0)
  lifetime_points Int   @default(0)
  tier           String @default("bronze") // bronze | silver | gold
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  version        Int      @default(1)

  salon  Salon  @relation(fields: [salon_id], references: [id])
  client Client @relation(fields: [client_id], references: [id])

  @@index([salon_id])
}

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  salon_id    String
  client_id   String
  type        String                        // earn | redeem
  points      Int
  description String?
  ticket_id   String?
  reward_id   String?
  created_at  DateTime @default(now())

  @@index([salon_id])
  @@index([client_id])
}

// ════════════════════════════════════════════
// MEMBERSHIPS
// ════════════════════════════════════════════

model MembershipPlan {
  id                       String  @id @default(uuid())
  salon_id                 String
  name                     String
  description              String?
  price_cents              Int
  billing_cycle_days       Int     @default(30)
  payment_method           String  @default("in_person") // in_person | upfront
  min_commitment_cycles    Int?
  notice_period_days       Int?
  missed_payment_action    String  @default("pause") // pause | cancel | grace_period
  missed_payment_threshold Int?
  credit_rollover          Boolean @default(false)
  perk_apply_mode          String  @default("auto") // auto | manual
  freeze_allowed           Boolean @default(true)
  active                   Boolean @default(true)
  position                 Int     @default(0)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  version                  Int      @default(1)

  salon   Salon               @relation(fields: [salon_id], references: [id])
  members MembershipAccount[]
  perks   MembershipPerk[]

  @@index([salon_id])
}

model MembershipPerk {
  id                   String  @id @default(uuid())
  plan_id              String
  type                 String  @default("percentage_discount") // percentage_discount | free_service | service_credit
  discount_percentage  Int?
  service_catalog_id   String?
  category_id          String?
  credit_amount_cents  Int?
  quantity_per_cycle   Int?
  position             Int     @default(0)

  plan MembershipPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@index([plan_id])
}

model MembershipAccount {
  id          String   @id @default(uuid())
  plan_id     String
  client_id   String   @unique
  status      String   @default("active") // active | frozen | cancelled
  start_date  DateTime
  next_billing DateTime?
  frozen_at   DateTime?
  cancelled_at DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  version     Int      @default(1)

  plan   MembershipPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  client Client         @relation(fields: [client_id], references: [id])
}

