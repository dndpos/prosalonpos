}

model PunchAuditLog {
  id          String   @id @default(uuid())
  punch_id    String?
  staff_id    String   // the staff whose punch was changed
  action      String   // created | edited | deleted
  old_value   String?  // JSON: { type, timestamp } before change
  new_value   String?  // JSON: { type, timestamp } after change
