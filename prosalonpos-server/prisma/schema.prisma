  staff_id  String
  type      String   // in | out
  timestamp DateTime @default(now())
  manual    Boolean  @default(false)
  created_at DateTime @default(now())

  staff Staff @relation(fields: [staff_id], references: [id])
  audit_logs PunchAuditLog[]

